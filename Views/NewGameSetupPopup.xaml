<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="SigmaChess.Views.NewGameSetupPopup"
               CanBeDismissedByTappingOutsideOfPopup="False"
               Color="Transparent">
    <toolkit:Popup.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </toolkit:Popup.Resources>
    <Border Padding="22"
            Background="{StaticResource GlassCardBrush}"
            Stroke="{StaticResource GlassStrokeBrush}"
            StrokeShape="RoundRectangle 18"
            StrokeThickness="1"
            WidthRequest="340">
        <Border.Shadow>
            <Shadow Brush="#88000000"
                    Offset="0,12"
                    Opacity="0.38"
                    Radius="22" />
        </Border.Shadow>
        <ScrollView MaximumHeightRequest="520">
            <VerticalStackLayout Spacing="12">
                <Label FontAttributes="Bold"
                       FontSize="18"
                       Text="New game"
                       TextColor="{StaticResource GlassTitleText}" />

                <Label FontSize="13"
                       Text="Layout"
                       TextColor="{StaticResource GlassSubtitleText}" />
                <Border Padding="12,10"
                        Background="{StaticResource GlassChromeBrush}"
                        Stroke="{StaticResource GlassStrokeSoftBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLayoutPickTapped" />
                    </Border.GestureRecognizers>
                    <Label x:Name="LayoutChoiceLabel"
                           FontSize="15"
                           TextColor="{StaticResource GlassTitleText}" />
                </Border>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Label Grid.Column="0"
                           FontSize="14"
                           Text="Same time for both"
                           TextColor="{StaticResource GlassSubtitleText}"
                           VerticalOptions="Center" />
                    <Switch x:Name="SameTimeSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"
                            IsToggled="True"
                            Toggled="OnSameTimeToggled" />
                </Grid>

                <VerticalStackLayout x:Name="SharedTimeSection"
                                     Spacing="8">
                    <Label FontSize="13"
                           Text="Time control"
                           TextColor="{StaticResource GlassSubtitleText}" />
                    <Border Padding="12,10"
                            Background="{StaticResource GlassChromeBrush}"
                            Stroke="{StaticResource GlassStrokeSoftBrush}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSharedTimePickTapped" />
                        </Border.GestureRecognizers>
                        <Label x:Name="SharedTimeChoiceLabel"
                               FontSize="15"
                               TextColor="{StaticResource GlassTitleText}" />
                    </Border>
                    <Label FontSize="11"
                           Text="Custom minutes (optional, overrides preset)"
                           TextColor="{StaticResource GlassSubtitleText}" />
                    <Entry x:Name="SharedCustomMinutes"
                           FontSize="15"
                           Keyboard="Numeric"
                           Placeholder="e.g. 25"
                           TextColor="{StaticResource GlassTitleText}" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="SeparateTimeSection"
                                     IsVisible="False"
                                     Spacing="10">
                    <Label FontAttributes="Bold"
                           FontSize="13"
                           Text="White"
                           TextColor="{StaticResource GlassTitleText}" />
                    <Border Padding="12,10"
                            Background="{StaticResource GlassChromeBrush}"
                            Stroke="{StaticResource GlassStrokeSoftBrush}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnWhiteTimePickTapped" />
                        </Border.GestureRecognizers>
                        <Label x:Name="WhiteTimeChoiceLabel"
                               FontSize="15"
                               TextColor="{StaticResource GlassTitleText}" />
                    </Border>
                    <Entry x:Name="WhiteCustomMinutes"
                           FontSize="14"
                           Keyboard="Numeric"
                           Placeholder="Custom min"
                           TextColor="{StaticResource GlassTitleText}" />
                    <Label FontAttributes="Bold"
                           FontSize="13"
                           Text="Black"
                           TextColor="{StaticResource GlassTitleText}" />
                    <Border Padding="12,10"
                            Background="{StaticResource GlassChromeBrush}"
                            Stroke="{StaticResource GlassStrokeSoftBrush}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBlackTimePickTapped" />
                        </Border.GestureRecognizers>
                        <Label x:Name="BlackTimeChoiceLabel"
                               FontSize="15"
                               TextColor="{StaticResource GlassTitleText}" />
                    </Border>
                    <Entry x:Name="BlackCustomMinutes"
                           FontSize="14"
                           Keyboard="Numeric"
                           Placeholder="Custom min"
                           TextColor="{StaticResource GlassTitleText}" />
                </VerticalStackLayout>

                <Grid Margin="0,8,0,0"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">
                    <Button Grid.Column="1"
                            Padding="14,10"
                            Background="{StaticResource GlassNavButtonBrush}"
                            BorderWidth="0"
                            Clicked="OnCancelClicked"
                            CornerRadius="14"
                            Text="Cancel"
                            TextColor="{StaticResource GlassTitleText}" />
                    <Button Grid.Column="2"
                            Padding="14,10"
                            Background="{StaticResource GlassPrimaryButtonBrush}"
                            BorderWidth="0"
                            Clicked="OnStartClicked"
                            CornerRadius="14"
                            Text="Start"
                            TextColor="#16161C" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
