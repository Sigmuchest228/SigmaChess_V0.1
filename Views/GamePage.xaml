<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SigmaChess.ViewModels"
             x:Class="SigmaChess.Views.GamePage"
             x:DataType="viewModels:GameViewModel"
             Title="Game">

    <Grid Padding="12,8"
          RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="8">

        <!-- Хедер: Назад | ход | таймер‑слот | ⚙ -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="8">
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="20"
                    Padding="10,4"
                    Command="{Binding BackToMenuCommand}" />
            <Label Grid.Column="1"
                   Text="{Binding CurrentTurnText}"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Border Grid.Column="2"
                    x:Name="TimerSlot"
                    WidthRequest="84"
                    HeightRequest="36"
                    Stroke="#888"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 6"
                    BackgroundColor="#EEE">
                <Label Text="--:--"
                       FontSize="14"
                       TextColor="#666"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            <Button Grid.Column="3"
                    Text="⚙"
                    FontSize="20"
                    Padding="10,4"
                    Clicked="OnSettingsClicked" />
        </Grid>

        <!-- Статус (Шах) + результат -->
        <VerticalStackLayout Grid.Row="1" Spacing="2">
            <Label Text="{Binding GameStatusText}"
                   FontSize="16"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"
                   TextColor="#B71C1C"
                   MinimumHeightRequest="20" />
            <Label Text="{Binding GameResultText}"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"
                   TextColor="#1565C0"
                   MinimumHeightRequest="22" />
        </VerticalStackLayout>

        <!-- Доска + координаты в едином 9×9 Grid: общие *‑строки/колонки ⇒ идеальное выравнивание -->
        <Grid Grid.Row="2"
              x:Name="BoardWithCoords"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              WidthRequest="{Binding BoardGridSize}"
              HeightRequest="{Binding BoardGridSize}"
              ColumnDefinitions="28,*,*,*,*,*,*,*,*"
              RowDefinitions="*,*,*,*,*,*,*,*,28">
            <!-- 8 рангов в col=0 (rows 0..7) и 8 файлов в row=8 (cols 1..8)
                 создаются в code-behind для возможности переворота. -->
            <Grid x:Name="BoardGrid"
                  Grid.Row="0" Grid.RowSpan="8"
                  Grid.Column="1" Grid.ColumnSpan="8"
                  RowDefinitions="*,*,*,*,*,*,*,*"
                  ColumnDefinitions="*,*,*,*,*,*,*,*"
                  RowSpacing="0"
                  ColumnSpacing="0" />
        </Grid>

        <!-- Нижний слот под действия (Сдаться / Ничья / История) — заглушка на будущее -->
        <Border Grid.Row="3"
                HeightRequest="48"
                Stroke="#CCC"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6"
                BackgroundColor="#FAFAFA" />
    </Grid>
</ContentPage>
