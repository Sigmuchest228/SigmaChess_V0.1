<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SigmaChess.ViewModels"
             x:Class="SigmaChess.Views.GamePage"
             x:DataType="viewModels:GameViewModel"
             BackgroundColor="{StaticResource GlassPageFallback}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="MoveHistoryRowTemplate"
                          x:DataType="viewModels:MoveHistoryRow">
                <Grid ColumnDefinitions="32,*,*"
                      Padding="0,3"
                      ColumnSpacing="6"
                      MinimumWidthRequest="120"
                      HorizontalOptions="Fill">
                    <Label Grid.Column="0"
                           FontSize="12"
                           Text="{Binding NumberLabel}"
                           TextColor="{StaticResource GlassSubtitleText}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           FontSize="12"
                           Text="{Binding WhiteMove}"
                           TextColor="{StaticResource GlassTitleText}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="2"
                           FontSize="12"
                           Text="{Binding BlackMove}"
                           TextColor="{StaticResource GlassTitleText}"
                           VerticalOptions="Center" />
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="12,8"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="8">

        <!-- Хедер: только назад -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="8">
            <Button Grid.Column="0"
                    Style="{StaticResource GlassChevronBackButton}"
                    Text="‹"
                    Padding="10,6"
                    Command="{Binding BackToMenuCommand}" />
        </Grid>

        <Grid Grid.Row="1"
              MinimumHeightRequest="280">

            <!-- Обычный режим: чёрные сверху, белые снизу; история ходов полосой под доской (как в F2F по ширине). -->
            <Grid IsVisible="{Binding IsCasualLayout}"
                  ColumnDefinitions="*"
                  RowDefinitions="Auto,*,Auto,Auto"
                  RowSpacing="8">
                <Border Grid.Row="0"
                        HorizontalOptions="Center"
                        MinimumWidthRequest="72"
                        Padding="10,8"
                        Background="{StaticResource GlassNavButtonBrush}"
                        Stroke="{StaticResource GlassStrokeSoftBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="0">
                        <Label FontSize="10"
                               Text="Black"
                               TextColor="{StaticResource GlassSubtitleText}" />
                        <Label FontAttributes="Bold"
                               FontSize="14"
                               Text="{Binding BlackClockText, Mode=OneWay}"
                               TextColor="{StaticResource GlassTitleText}" />
                    </VerticalStackLayout>
                </Border>
                <Grid x:Name="CasualBoardHost"
                      Grid.Row="1"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Grid x:Name="BoardWithCoords"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="{Binding BoardGridSize}"
                          HeightRequest="{Binding BoardGridSize}"
                          ColumnDefinitions="28,*,*,*,*,*,*,*,*"
                          RowDefinitions="*,*,*,*,*,*,*,*,28">
                        <Grid x:Name="BoardGrid"
                              Grid.Row="0" Grid.RowSpan="8"
                              Grid.Column="1" Grid.ColumnSpan="8"
                              RowDefinitions="*,*,*,*,*,*,*,*"
                              ColumnDefinitions="*,*,*,*,*,*,*,*"
                              RowSpacing="0"
                              ColumnSpacing="0" />
                    </Grid>
                </Grid>
                <Border Grid.Row="2"
                        HorizontalOptions="Center"
                        MinimumWidthRequest="72"
                        Padding="10,8"
                        Background="{StaticResource GlassPrimaryButtonBrush}"
                        Stroke="{StaticResource GlassStrokeBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="0">
                        <Label FontSize="10"
                               Text="White"
                               TextColor="{StaticResource Gray600}" />
                        <Label FontAttributes="Bold"
                               FontSize="14"
                               Text="{Binding WhiteClockText, Mode=OneWay}"
                               TextColor="{StaticResource PrimaryDarkText}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="3"
                        Padding="10,8"
                        Background="{StaticResource GlassTransparentBrush}"
                        Stroke="{StaticResource GlassStrokeSoftBrush}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        HorizontalOptions="Fill"
                        MaximumHeightRequest="128">
                    <CollectionView ItemsSource="{Binding MoveRows}"
                                    BackgroundColor="Transparent"
                                    ItemTemplate="{StaticResource MoveHistoryRowTemplate}" />
                </Border>
            </Grid>

            <!-- Режим «за столом»: полноширинные полосы истории (узкие боковые колонки сжимали текст в «лесенку»). -->
            <Grid IsVisible="{Binding IsFaceToFaceLayout}"
                  RowDefinitions="Auto,*,Auto"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill"
                  RowSpacing="10">

                <VerticalStackLayout Grid.Row="0"
                                     Spacing="8"
                                     HorizontalOptions="Fill">
                    <HorizontalStackLayout HorizontalOptions="End"
                                           Spacing="0">
                        <Border Padding="14,8"
                                Background="{StaticResource GlassNavButtonBrush}"
                                Stroke="{StaticResource GlassStrokeSoftBrush}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                MinimumWidthRequest="104"
                                Rotation="180">
                            <VerticalStackLayout Spacing="0">
                                <Label FontSize="10"
                                       Text="Black"
                                       TextColor="{StaticResource GlassSubtitleText}" />
                                <Label FontAttributes="Bold"
                                       FontSize="14"
                                       Text="{Binding BlackClockText, Mode=OneWay}"
                                       TextColor="{StaticResource GlassTitleText}" />
                            </VerticalStackLayout>
                        </Border>
                    </HorizontalStackLayout>
                    <Border Padding="10,8"
                            Background="{StaticResource GlassTransparentBrush}"
                            Stroke="{StaticResource GlassStrokeSoftBrush}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            HorizontalOptions="Fill"
                            MaximumHeightRequest="128">
                        <Grid Rotation="180"
                              HorizontalOptions="Fill"
                              VerticalOptions="Fill">
                            <CollectionView ItemsSource="{Binding MoveRows}"
                                            BackgroundColor="Transparent"
                                            ItemTemplate="{StaticResource MoveHistoryRowTemplate}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Grid x:Name="FaceToFaceBoardHost"
                      Grid.Row="1"
                      WidthRequest="{Binding BoardGridSize}"
                      HeightRequest="{Binding BoardGridSize}"
                      HorizontalOptions="Center"
                      VerticalOptions="Center" />

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="8"
                                     HorizontalOptions="Fill">
                    <HorizontalStackLayout HorizontalOptions="Start"
                                           Spacing="0">
                        <Border Padding="14,8"
                                Background="{StaticResource GlassPrimaryButtonBrush}"
                                Stroke="{StaticResource GlassStrokeBrush}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                MinimumWidthRequest="104">
                            <VerticalStackLayout Spacing="0">
                                <Label FontSize="10"
                                       Text="White"
                                       TextColor="{StaticResource Gray600}" />
                                <Label FontAttributes="Bold"
                                       FontSize="14"
                                       Text="{Binding WhiteClockText, Mode=OneWay}"
                                       TextColor="{StaticResource PrimaryDarkText}" />
                            </VerticalStackLayout>
                        </Border>
                    </HorizontalStackLayout>
                    <Border Padding="10,8"
                            Background="{StaticResource GlassTransparentBrush}"
                            Stroke="{StaticResource GlassStrokeSoftBrush}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            HorizontalOptions="Fill"
                            MaximumHeightRequest="128">
                        <CollectionView ItemsSource="{Binding MoveRows}"
                                        BackgroundColor="Transparent"
                                        ItemTemplate="{StaticResource MoveHistoryRowTemplate}" />
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Нижняя панель: только обводка, фон не перекрывает обои -->
        <Border Grid.Row="2"
                Padding="12,10"
                Background="{StaticResource GlassTransparentBrush}"
                Stroke="{StaticResource GlassStrokeSoftBrush}"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                  ColumnSpacing="12">
                <Button Grid.Column="0"
                        Background="{StaticResource GlassPrimaryButtonBrush}"
                        BorderWidth="0"
                        Clicked="OnSettingsClicked"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="13"
                        Padding="16,10"
                        Text="Settings"
                        TextColor="#16161C" />
                <BoxView Grid.Column="1"
                         Color="Transparent" />
                <Button Grid.Column="2"
                        MinimumWidthRequest="52"
                        Style="{StaticResource GlassGameStepButton}"
                        Text="◀"
                        Command="{Binding StepBackwardCommand}" />
                <Button Grid.Column="3"
                        MinimumWidthRequest="52"
                        Style="{StaticResource GlassGameStepButton}"
                        Text="▶"
                        Command="{Binding StepForwardCommand}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
