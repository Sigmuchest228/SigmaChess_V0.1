<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SigmaChess.ViewModels"
             xmlns:views="clr-namespace:SigmaChess.Views"
             x:Class="SigmaChess.Views.PuzzleSolvePage"
             x:DataType="viewModels:PuzzleSolveViewModel"
             BackgroundColor="{StaticResource GlassPageFallback}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="12,8"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="8">

        <views:WallpaperBackdrop Grid.RowSpan="3"
                                 InputTransparent="True" />

        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="8">
            <Button Grid.Column="0"
                    Style="{StaticResource GlassChevronBackButton}"
                    Text="‹"
                    Padding="10,6"
                    Command="{Binding GoBackCommand}" />
            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center">
                <Label FontAttributes="Bold"
                       FontSize="16"
                       LineBreakMode="TailTruncation"
                       Text="{Binding HeaderText}"
                       TextColor="{StaticResource GlassTitleText}" />
                <Label FontSize="13"
                       LineBreakMode="WordWrap"
                       Opacity="0.92"
                       Text="{Binding StatusText}"
                       TextColor="{StaticResource GlassSubtitleText}" />
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1"
              HorizontalOptions="Center"
              VerticalOptions="Center">
            <Grid x:Name="BoardWithCoords"
                  HorizontalOptions="Center"
                  VerticalOptions="Center"
                  WidthRequest="{Binding BoardGridSize}"
                  HeightRequest="{Binding BoardGridSize}"
                  ColumnDefinitions="28,*,*,*,*,*,*,*,*"
                  RowDefinitions="*,*,*,*,*,*,*,*,28">
                <Grid x:Name="BoardGrid"
                      Grid.Row="0" Grid.RowSpan="8"
                      Grid.Column="1" Grid.ColumnSpan="8"
                      RowDefinitions="*,*,*,*,*,*,*,*"
                      ColumnDefinitions="*,*,*,*,*,*,*,*"
                      RowSpacing="0"
                      ColumnSpacing="0" />
            </Grid>
        </Grid>

        <Label Grid.Row="2"
               Margin="0,4,0,0"
               FontSize="12"
               HorizontalTextAlignment="Center"
               Opacity="0.85"
               Text="Move the correct piece — one winning move."
               TextColor="{StaticResource GlassSubtitleText}" />
    </Grid>
</ContentPage>
