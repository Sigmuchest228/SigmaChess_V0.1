<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SigmaChess.ViewModels"
             x:Class="SigmaChess.Views.GameSettingsPanel"
             x:DataType="viewModels:GameViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="14">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="Auto-flip board each move"
                   TextColor="{StaticResource GlassSubtitleText}"
                   VerticalOptions="Center" />
            <Switch Grid.Column="1"
                    IsToggled="{Binding AutoFlipEnabled}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="Highlight last move"
                   TextColor="{StaticResource GlassSubtitleText}"
                   VerticalOptions="Center" />
            <Switch Grid.Column="1"
                    IsToggled="{Binding HighlightLastMoveEnabled}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="Auto-queen promotion"
                   TextColor="{StaticResource GlassSubtitleText}"
                   VerticalOptions="Center" />
            <Switch Grid.Column="1"
                    IsToggled="{Binding AutoQueenEnabled}" />
        </Grid>
    </VerticalStackLayout>
</ContentView>
