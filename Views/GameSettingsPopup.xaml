<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:viewModels="clr-namespace:SigmaChess.ViewModels"
               x:Class="SigmaChess.Views.GameSettingsPopup"
               x:DataType="viewModels:GameViewModel"
               CanBeDismissedByTappingOutsideOfPopup="True"
               Color="Transparent">
    <Border Padding="20"
            StrokeShape="RoundRectangle 12"
            BackgroundColor="#FAFAFA"
            WidthRequest="320">
        <VerticalStackLayout Spacing="14">
            <Label Text="Game settings"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#1A1A1A" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="Auto-flip board each move"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding AutoFlipEnabled}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="Highlight last move"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding HighlightLastMoveEnabled}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="Auto-queen promotion"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding AutoQueenEnabled}" />
            </Grid>

            <Button Text="New game"
                    Clicked="OnNewGameClicked" />
            <Button Text="Close"
                    Clicked="OnCloseClicked"
                    BackgroundColor="Transparent"
                    TextColor="#1565C0" />
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
