<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SigmaChess.Views.MainBottomNavBar">
    <ContentView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentView.Resources>
    <Border Padding="8"
            Background="{StaticResource GlassChromeBrush}"
            Stroke="{StaticResource GlassStrokeBrush}"
            StrokeShape="RoundRectangle 18"
            StrokeThickness="1">
        <Border.Shadow>
            <Shadow Brush="#90000000"
                    Offset="0,14"
                    Opacity="0.42"
                    Radius="28" />
        </Border.Shadow>
        <Grid ColumnDefinitions="*,*,*,*"
              ColumnSpacing="8">
            <Button Grid.Column="0"
                    BorderWidth="0"
                    Command="{Binding NavigateHomeCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    FontSize="13"
                    HorizontalOptions="Fill"
                    LineBreakMode="WordWrap"
                    Padding="6,10"
                    Text="Home"
                    TextColor="{StaticResource GlassTitleText}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource GlassNavButtonBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeSelected}"
                                         TargetType="Button"
                                         Value="True">
                                <Setter Property="Background" Value="{StaticResource GlassNavButtonSelectedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Grid.Column="1"
                    BorderWidth="0"
                    Command="{Binding NavigatePuzzlesCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    FontSize="13"
                    HorizontalOptions="Fill"
                    LineBreakMode="WordWrap"
                    Padding="6,10"
                    Text="Puzzles"
                    TextColor="{StaticResource GlassTitleText}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource GlassNavButtonBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPuzzlesSelected}"
                                         TargetType="Button"
                                         Value="True">
                                <Setter Property="Background" Value="{StaticResource GlassNavButtonSelectedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Grid.Column="2"
                    BorderWidth="0"
                    Command="{Binding NavigateFollowsCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    FontSize="13"
                    HorizontalOptions="Fill"
                    LineBreakMode="WordWrap"
                    Padding="6,10"
                    Text="Follows"
                    TextColor="{StaticResource GlassTitleText}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource GlassNavButtonBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFollowsSelected}"
                                         TargetType="Button"
                                         Value="True">
                                <Setter Property="Background" Value="{StaticResource GlassNavButtonSelectedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Grid.Column="3"
                    Background="{StaticResource GlassNavButtonBrush}"
                    BorderWidth="0"
                    Command="{Binding NavigateSettingsCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    FontSize="13"
                    HorizontalOptions="Fill"
                    LineBreakMode="WordWrap"
                    Padding="6,10"
                    Text="Settings"
                    TextColor="{StaticResource GlassTitleText}" />
        </Grid>
    </Border>
</ContentView>
