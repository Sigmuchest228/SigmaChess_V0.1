{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["UserNameLower"],
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "ChessGames": {
      "$gameId": {
        ".read": "auth != null && data.exists()",
        ".write": "auth != null && (!data.exists() ? (newData.child('WhiteUid').val() == auth.uid || newData.child('BlackUid').val() == auth.uid) : (data.child('WhiteUid').val() == auth.uid || data.child('BlackUid').val() == auth.uid))"
      }
    },
    "respectReceived": {
      "$targetUid": {
        ".read": "auth != null",
        "$respecterUid": {
          ".write": "auth != null && auth.uid == $respecterUid",
          ".validate": "!newData.exists() || (newData.isBoolean() && newData.val() == true)"
        }
      }
    }
  }
}
