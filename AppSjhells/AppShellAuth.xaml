<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="SigmaChess.AppShellAuth"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:m="clr-namespace:SigmaChess"
    xmlns:views="clr-namespace:SigmaChess.Views"
    Title="SigmaChess"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Loader"
            Route="LoaderPage"
            ContentTemplate="{DataTemplate views:LoaderPage}" />
        <ShellContent
            Title="Home"
            Route="MainPage"
            ContentTemplate="{DataTemplate m:MainPage}" />
        <ShellContent
            Title="Game"
            Route="GamePage"
            ContentTemplate="{DataTemplate views:GamePage}" />
        <ShellContent
            Title="Puzzles"
            Route="PuzzlesPage"
            ContentTemplate="{DataTemplate views:PuzzlesPage}" />
        <ShellContent
            Title="Follows"
            Route="FollowsPage"
            ContentTemplate="{DataTemplate views:FollowsPage}" />
    </TabBar>
</Shell>
