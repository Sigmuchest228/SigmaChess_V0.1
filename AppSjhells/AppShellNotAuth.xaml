<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="SigmaChess.AppShellNotAuth"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SigmaChess.Views"
    xmlns:m="clr-namespace:SigmaChess"
    FlyoutBehavior="Disabled"
    Shell.TabBarIsVisible="False"
    Title="SigmaChess">

    <FlyoutItem Title="Home">
        <ShellContent
            Title="Home"
            Route="MainPage"
            ContentTemplate="{DataTemplate m:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Play on 1 device">
        <ShellContent
            Title="Game"
            Route="GamePage"
            ContentTemplate="{DataTemplate views:GamePage}" />
    </FlyoutItem>
</Shell>
