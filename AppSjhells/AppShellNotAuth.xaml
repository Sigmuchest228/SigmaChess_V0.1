<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="SigmaChess.AppShellNotAuth"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:m="clr-namespace:SigmaChess"
    xmlns:views="clr-namespace:SigmaChess.Views"
    Title="SigmaChess"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <!-- Первый ShellContent — Loader, затем Auth. -->
    <TabBar>
        <ShellContent
            Title="Loader"
            Route="LoaderPage"
            ContentTemplate="{DataTemplate views:LoaderPage}" />
        <ShellContent
            Route="AuthPage"
            Title="Auth"
            ContentTemplate="{DataTemplate views:AuthPage}" />
        <ShellContent
            Route="MainPage"
            Title="Home"
            ContentTemplate="{DataTemplate m:MainPage}" />
        <ShellContent
            Route="GamePage"
            Title="Game"
            ContentTemplate="{DataTemplate views:GamePage}" />
    </TabBar>
</Shell>
