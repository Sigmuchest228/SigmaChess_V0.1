<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SigmaChess.ViewModels"
             x:Class="SigmaChess.MainPage"
             x:DataType="viewModels:MainPageViewModel"
             Title="Home"
             BackgroundColor="#3E3E3E">
    <Grid Padding="8"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="8">
        <Border Grid.Row="0"
                Stroke="#181818"
                StrokeThickness="1"
                BackgroundColor="#4A4A4A"
                Padding="6"
                StrokeShape="RoundRectangle 8">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="6">
                <Button Grid.Column="0"
                        Text="Log In"
                        Command="{Binding OpenLoginCommand}"
                        IsVisible="{Binding IsGuest}"
                        FontSize="11"
                        BackgroundColor="#D7D7D7"
                        TextColor="#121212"
                        Padding="10,3"
                        MinimumHeightRequest="30" />
                <Label Grid.Column="1"
                       Text="SIGMA CHESS"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#ECECEC"
                       FontAttributes="Bold"
                       FontSize="20" />
                <Button Grid.Column="2"
                        Text="Sign up"
                        Command="{Binding OpenSignupCommand}"
                        IsVisible="{Binding IsGuest}"
                        FontSize="11"
                        BackgroundColor="#D7D7D7"
                        TextColor="#121212"
                        Padding="10,3"
                        MinimumHeightRequest="30" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="10">
                <Border Stroke="#1D1D1D"
                        StrokeThickness="1"
                        BackgroundColor="#595959"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="64,*"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#BFC2B5"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="64"
                                WidthRequest="64" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Button Text="Play on 1 device"
                                    Command="{Binding OpenOneDeviceGameCommand}"
                                    BackgroundColor="#595959"
                                    TextColor="#F2F2F2"
                                    HorizontalOptions="Start"
                                    Padding="0"
                                    FontAttributes="Bold" />
                            <Label Text="Pass the device and play locally."
                                   FontSize="12"
                                   TextColor="#D0D0D0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Stroke="#1D1D1D"
                        StrokeThickness="1"
                        BackgroundColor="#595959"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="64,*"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#BFC2B5"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="64"
                                WidthRequest="64" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Button Text="Play with bots"
                                    Command="{Binding OpenBotsCommand}"
                                    BackgroundColor="#595959"
                                    TextColor="#F2F2F2"
                                    HorizontalOptions="Start"
                                    Padding="0"
                                    FontAttributes="Bold" />
                            <Label Text="Choose bot level and play online."
                                   FontSize="12"
                                   TextColor="#D0D0D0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Stroke="#1D1D1D"
                        StrokeThickness="1"
                        BackgroundColor="#595959"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="64,*"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#BFC2B5"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="64"
                                WidthRequest="64" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Button Text="Solve puzzles"
                                    Command="{Binding OpenPuzzlesCommand}"
                                    BackgroundColor="#595959"
                                    TextColor="#F2F2F2"
                                    HorizontalOptions="Start"
                                    Padding="0"
                                    FontAttributes="Bold" />
                            <Label Text="Sharpen your tactical skills daily."
                                   FontSize="12"
                                   TextColor="#D0D0D0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Stroke="#1D1D1D"
                        StrokeThickness="1"
                        BackgroundColor="#595959"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="64,*"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#BFC2B5"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="64"
                                WidthRequest="64" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Button Text="Add friends"
                                    Command="{Binding OpenFriendsCommand}"
                                    BackgroundColor="#595959"
                                    TextColor="#F2F2F2"
                                    HorizontalOptions="Start"
                                    Padding="0"
                                    FontAttributes="Bold" />
                            <Label Text="Find players and challenge together."
                                   FontSize="12"
                                   TextColor="#D0D0D0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Stroke="#1D1D1D"
                        StrokeThickness="1"
                        BackgroundColor="#595959"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="64,*"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#BFC2B5"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="64"
                                WidthRequest="64" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Button Text="Watch"
                                    Command="{Binding OpenWatchCommand}"
                                    BackgroundColor="#595959"
                                    TextColor="#F2F2F2"
                                    HorizontalOptions="Start"
                                    Padding="0"
                                    FontAttributes="Bold" />
                            <Label Text="Catch important chess events."
                                   FontSize="12"
                                   TextColor="#D0D0D0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                Stroke="#171717"
                StrokeThickness="1"
                BackgroundColor="#4A4A4A"
                Padding="4"
                StrokeShape="RoundRectangle 8">
            <Grid ColumnDefinitions="*,*,*,*,*"
                  ColumnSpacing="4">
                <Button Grid.Column="0"
                        Text="Home"
                        Command="{Binding OpenHomeCommand}"
                        FontSize="11"
                        BackgroundColor="#4A4A4A"
                        TextColor="#F1F1F1" />
                <Button Grid.Column="1"
                        Text="Puzzles"
                        Command="{Binding OpenPuzzlesCommand}"
                        FontSize="11"
                        BackgroundColor="#4A4A4A"
                        TextColor="#F1F1F1" />
                <Button Grid.Column="2"
                        Text="Learn"
                        Command="{Binding OpenLearnCommand}"
                        FontSize="11"
                        BackgroundColor="#4A4A4A"
                        TextColor="#F1F1F1" />
                <Button Grid.Column="3"
                        Text="Watch"
                        Command="{Binding OpenWatchCommand}"
                        FontSize="11"
                        BackgroundColor="#4A4A4A"
                        TextColor="#F1F1F1" />
                <Button Grid.Column="4"
                        Text="Menu"
                        Command="{Binding OpenMenuCommand}"
                        FontSize="11"
                        BackgroundColor="#4A4A4A"
                        TextColor="#F1F1F1" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
